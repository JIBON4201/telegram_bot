# TELEGRAM_BOT_TOKEN: The API token for your Telegram bot from @BotFather.
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN"

# DATABASE_URL: Your PostgreSQL connection string (Standard for Render).
DATABASE_URL="postgres://user:password@host:port/dbname"

# ADMIN_TG_ID: Your Telegram User ID (Numeric) for full owner access.
ADMIN_TG_ID="YOUR_TELEGRAM_ID"

# GEMINI_API_KEY: Optional - Required only if using AI features.
GEMINI_API_KEY="YOUR_GEMINI_KEY"

# APP_URL: The URL of your Render deployment (e.g., https://my-bot.onrender.com).
# Required if you want to use Webhooks instead of Long Polling.
APP_URL="https://your-app.onrender.com"

# NODE_ENV: Set to 'production' for live deployment.
NODE_ENV="production"
